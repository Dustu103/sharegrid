# ─────────────────────────────────────────────────────────────────
# ShareGrid Backend — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL / Neon DB connection string)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sharegrid?sslmode=disable

# Logging: debug | info | warn | error
LOG_LEVEL=info

# ── Game Tuning (overrides hardcoded defaults in game/rules.js) ──
GRID_ROWS=40
GRID_COLS=50

# Milliseconds a user must wait between successive tile claims
USER_COOLDOWN_MS=3000

# Milliseconds a tile is locked after being captured (can't steal)
TILE_LOCK_MS=1000

# Tile decay: tiles return to neutral after TILE_DECAY_MS of inactivity
TILE_DECAY_ENABLED=false
TILE_DECAY_MS=300000

{
  "name": "sharegrid-backend",
  "version": "1.0.0",
  "description": "ShareGrid real-time WebSocket server — Node.js + Express + SQLite",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev":   "nodemon server.js --watch . --ext js,json --ignore '../frontend'",
    "lint":  "eslint '**/*.js' --ignore-pattern 'node_modules'"
  },
  "keywords": ["websocket", "realtime", "grid", "game", "multiplayer"],
  "author": "ShareGrid Team",
  "license": "MIT",
  "dependencies": {
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.1",
    "express":        "^4.18.2",
    "ioredis":        "^5.3.2",
    "pg":             "^8.11.3",
    "uuid":           "^9.0.0",
    "ws":             "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
